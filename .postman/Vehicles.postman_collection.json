{
  "info": {
    "name": "Vehicles Module",
    "_postman_id": "vehicles-module-collection",
    "description": "Collection to test the Vehicles microservice.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Create Vehicle",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "body": { "mode": "raw", "raw": "{\n  \"make\": \"Toyota\",\n  \"model\": \"Supra\",\n  \"plate\": \"ABC-123\",\n  \"active\": false\n}" },
        "url": "{{baseUrl}}/api/users/{{userId}}/vehicles"
      },
      "event": [ { "listen": "test", "script": { "exec": [ "var json = pm.response.json();", "if (json && json.id) { pm.environment.set('vehicleId', json.id); }", "pm.test('Status is 201', function () { pm.response.to.have.status(201); });" ] } } ]
    },
    { "name": "List Vehicles", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": "{{baseUrl}}/api/users/{{userId}}/vehicles" }, "response": [] },
    { "name": "Activate Vehicle", "request": { "method": "PATCH", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": "{{baseUrl}}/api/vehicles/{{vehicleId}}/activate" }, "response": [] },
    { "name": "Delete Vehicle", "request": { "method": "DELETE", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": "{{baseUrl}}/api/vehicles/{{vehicleId}}" }, "response": [] }
  ]
}
