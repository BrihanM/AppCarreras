{
  "info": {
    "name": "Users Module",
    "_postman_id": "users-module-collection",
    "description": "Collection to test the Users microservice.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Create User",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Test Pilot\",\n  \"local_zone\": \"Zona A\",\n  \"city_area\": \"Ciudad\",\n  \"state_zone\": \"Estado\",\n  \"country_zone\": \"Pais\",\n  \"rank\": \"A\",\n  \"category_id\": null,\n  \"victories\": 0,\n  \"defeats\": 0,\n  \"consecutive_challenges\": 0,\n  \"state\": \"active\",\n  \"account_id\": \"{{accountId}}\"\n}"
        },
        "url": "{{baseUrl}}/api/users"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var json = pm.response.json();",
              "if (json && json.id) { pm.environment.set('userId', json.id); }",
              "pm.test('Status is 201', function () { pm.response.to.have.status(201); });"
            ]
          }
        }
      ]
    },
    {
      "name": "List Users",
      "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": "{{baseUrl}}/api/users" },
      "response": []
    },
    {
      "name": "Get User",
      "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": "{{baseUrl}}/api/users/{{userId}}" },
      "response": []
    },
    {
      "name": "Update User",
      "request": {
        "method": "PUT",
        "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "body": { "mode": "raw", "raw": "{\n  \"name\": \"Test Pilot Updated\"\n}" },
        "url": "{{baseUrl}}/api/users/{{userId}}"
      },
      "response": []
    },
    {
      "name": "Delete User",
      "request": { "method": "DELETE", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": "{{baseUrl}}/api/users/{{userId}}" },
      "response": []
    }
  ]
}
