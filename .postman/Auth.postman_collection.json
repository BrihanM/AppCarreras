{
  "info": {
    "name": "Auth Module",
    "_postman_id": "auth-module-collection",
    "description": "Collection to test the Auth microservice (accounts, users, auth).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Create Account",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"testuser\",\n  \"email\": \"test@example.com\",\n  \"password\": \"Password123\",\n  \"photo\": null\n}"
        },
        "url": "{{baseUrl}}/api/accounts"
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var json = pm.response.json();",
              "if (json && json.id) { pm.environment.set('accountId', json.id); }",
              "pm.test('Status is 201', function () { pm.response.to.have.status(201); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"identifier\": \"testuser\",\n  \"password\": \"Password123\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/login"
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var json = pm.response.json();",
              "if (json && json.token) { pm.environment.set('token', json.token); }",
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Create User",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Test Pilot\",\n  \"local_zone\": \"Zona A\",\n  \"city_area\": \"Ciudad\",\n  \"state_zone\": \"Estado\",\n  \"country_zone\": \"Pais\",\n  \"rank\": \"A\",\n  \"category_id\": null,\n  \"victories\": 0,\n  \"defeats\": 0,\n  \"consecutive_challenges\": 0,\n  \"state\": \"active\",\n  \"account_id\": \"{{accountId}}\"\n}"
        },
        "url": "{{baseUrl}}/api/users"
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var json = pm.response.json();",
              "if (json && json.id) { pm.environment.set('userId', json.id); }",
              "pm.test('Status is 201', function () { pm.response.to.have.status(201); });"
            ]
          }
        }
      ]
    },
    {
      "name": "List Users",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{baseUrl}}/api/users"
      },
      "response": []
    },
    {
      "name": "Get User",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{baseUrl}}/api/users/{{userId}}"
      },
      "response": []
    },
    {
      "name": "Update User",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Test Pilot Updated\"\n}"
        },
        "url": "{{baseUrl}}/api/users/{{userId}}"
      },
      "response": []
    },
    {
      "name": "Delete User",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{baseUrl}}/api/users/{{userId}}"
      },
      "response": []
    },
    {
      "name": "Get Account",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/accounts/{{accountId}}"
      },
      "response": []
    },
    {
      "name": "Update Account",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"photo\": \"http://example.com/photo.png\"\n}"
        },
        "url": "{{baseUrl}}/api/accounts/{{accountId}}"
      },
      "response": []
    },
    {
      "name": "Delete Account",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": "{{baseUrl}}/api/accounts/{{accountId}}"
      },
      "response": []
    }
  ]
}
